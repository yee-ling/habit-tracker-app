<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_margin="@dimen/xs"
    app:cardCornerRadius="@dimen/xs"
    app:cardElevation="@dimen/xxxs">
    <LinearLayout
        android:id="@+id/llHabit"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/xs"
        android:orientation="vertical">
        <TextView
            android:id="@+id/tvName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="@dimen/tx_xl"
            android:textStyle="bold"
            android:text="@string/name" />
        <TextView
            android:id="@+id/tvFrequency"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textStyle="italic"
            android:text="@string/frequency" />
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <TextView
                android:id="@+id/tvProgress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/progress" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="@dimen/xxxxs"
                android:text="@string/slash" />
            <TextView
                android:id="@+id/tvRepeats"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/repeats" />
        </LinearLayout>
        <TextView
            android:id="@+id/tvCompleted"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/completed"
            app:drawableStartCompat="@drawable/ic_check_small"
            app:drawableTint="@color/green" />
    </LinearLayout>
    <com.google.android.material.progressindicator.CircularProgressIndicator
        android:id="@+id/circularCheckbox"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:trackThickness="@dimen/xxs"
        app:indicatorColor="@color/green"
        app:trackColor="@color/grey"
        app:indicatorDirectionCircular="clockwise"
        android:max="4"
        android:progress="2"
        android:layout_marginEnd="@dimen/xxxs"
        android:layout_gravity="center_vertical|end"/>
</androidx.cardview.widget.CardView>