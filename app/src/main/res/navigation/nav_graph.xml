<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">
    <fragment
        android:id="@+id/homeFragment"
        android:name="com.example.habittrackerapp.ui.home.HomeFragment"
        android:label="fragment_home"
        tools:layout="@layout/fragment_home" >
        <action
            android:id="@+id/action_home_to_addHabit"
            app:destination="@id/addHabitFragment" />
        <action
            android:id="@+id/action_home_to_habitDetails"
            app:destination="@id/habitDetailsFragment" />
    </fragment>
    <fragment
        android:id="@+id/addHabitFragment"
        android:name="com.example.habittrackerapp.ui.manageHabit.AddHabitFragment"
        android:label="AddHabitFragment"
        tools:layout="@layout/fragment_base_manage"/>
    <fragment
        android:id="@+id/myHabitFragment"
        android:name="com.example.habittrackerapp.ui.myHabit.MyHabitFragment"
        android:label="fragment_my_habit"
        tools:layout="@layout/fragment_my_habit" />
    <fragment
        android:id="@+id/habitDetailsFragment"
        android:name="com.example.habittrackerapp.ui.manageHabit.HabitDetailsFragment"
        android:label="fragment_habit_details"
        tools:layout="@layout/fragment_habit_details">
        <argument android:name="habit_id" app:argType="integer"/>
    </fragment>
</navigation>